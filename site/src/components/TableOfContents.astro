---
import type { Locale } from '../lib/i18n';
import { articleUiCopy } from '../lib/ui-copy';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  locale?: Locale;
}

const { headings, locale = 'es' } = Astro.props;
const h2and3 = headings.filter(h => h.depth <= 3);
const label = articleUiCopy[locale].tocLabel;
---

{h2and3.length > 0 && (
  <nav class="toc" aria-label={label}>
    <div class="toc-label">{label}</div>
    <ol>
      {h2and3.map(h => (
        <li class:list={[{ h3: h.depth === 3 }]}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .toc {
    position: sticky;
    top: 24px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-gutter: stable;
    scrollbar-width: thin;
    scrollbar-color: var(--color-em-border-3) transparent;
    padding: 20px;
    border: 1px solid var(--color-em-border-2);
    border-radius: var(--radius-lg);
    background: rgba(18, 18, 21, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .toc-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-em-fg-5);
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-em-border-1);
  }

  ol {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 14px;
  }

  li a {
    display: block;
    font-size: 13px;
    color: var(--color-em-fg-4);
    padding: 5px 8px;
    border-radius: var(--radius-sm);
    transition: color 0.28s var(--ease-out-em), background 0.28s var(--ease-out-em);
    line-height: 1.4;
  }

  li a:hover {
    color: var(--color-em-fg-1);
    background: rgba(255, 255, 255, 0.04);
  }

  li.h3 a {
    padding-left: 20px;
    font-size: 12px;
  }

  li a.active {
    color: var(--color-em-brand);
    background: rgba(220, 240, 93, 0.04);
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc a');

  if (links.length) {
    const headingEls = Array.from(links).map(a => document.getElementById(a.getAttribute('href')!.slice(1)));
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            links.forEach(a => a.classList.remove('active'));
            const link = document.querySelector<HTMLAnchorElement>(`.toc a[href="#${entry.target.id}"]`);
            link?.classList.add('active');
          }
        });
      },
      { rootMargin: '-20% 0% -70% 0%' }
    );

    headingEls.forEach(el => el && observer.observe(el));
  }
</script>
