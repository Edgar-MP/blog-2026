---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const h2and3 = headings.filter(h => h.depth <= 3);
---

{h2and3.length > 0 && (
  <nav class="toc" aria-label="Tabla de contenidos">
    <div class="toc-label">En este artículo</div>
    <ol>
      {h2and3.map(h => (
        <li class:list={[{ 'h3': h.depth === 3 }]}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ol>
    <!-- Progreso de lectura -->
    <div class="toc-progress">
      <span class="progress-label">Progreso</span>
      <div class="progress-bar">
        <div class="progress-fill" id="progress-fill"></div>
      </div>
    </div>
  </nav>
)}

<style>
  .toc {
    position: sticky;
    top: 96px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    padding: 20px;
    border: 1px solid var(--color-em-border-2);
    border-radius: var(--radius-lg);
    background: rgba(18, 18, 21, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .toc-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-em-fg-5);
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-em-border-1);
  }
  ol { list-style: none; display: flex; flex-direction: column; gap: 2px; margin-bottom: 14px; }
  li a {
    display: block;
    font-size: 13px;
    color: var(--color-em-fg-4);
    padding: 5px 8px;
    border-radius: var(--radius-sm);
    transition: color 0.2s, background 0.2s;
    line-height: 1.4;
  }
  li a:hover { color: var(--color-em-fg-1); background: rgba(255,255,255,0.04); }
  li.h3 a { padding-left: 20px; font-size: 12px; }
  li a.active { color: var(--color-em-brand); }

  .toc-progress {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px dashed var(--color-em-border-2);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .progress-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-em-fg-5);
  }
  .progress-bar {
    height: 2px;
    background: var(--color-em-border-2);
    border-radius: 9999px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--color-em-brand);
    width: 0%;
    transition: width 0.1s linear;
  }
</style>

<script>
  // Highlight active heading on scroll + reading progress
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc a');
  const progressFill = document.getElementById('progress-fill') as HTMLElement | null;

  if (links.length) {
    const headingEls = Array.from(links).map(a => document.getElementById(a.getAttribute('href')!.slice(1)));
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          links.forEach(a => a.classList.remove('active'));
          const link = document.querySelector<HTMLAnchorElement>(`.toc a[href="#${entry.target.id}"]`);
          link?.classList.add('active');
        }
      });
    }, { rootMargin: '-20% 0% -70% 0%' });
    headingEls.forEach(el => el && observer.observe(el));
  }

  // Update reading progress
  function updateProgress() {
    const article = document.querySelector('.prose-em') as HTMLElement | null;
    if (!article || !progressFill) return;
    const rect = article.getBoundingClientRect();
    const total = article.offsetHeight;
    const scrolled = Math.max(0, -rect.top);
    const pct = Math.min(100, (scrolled / total) * 100);
    progressFill.style.width = pct + '%';
  }
  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();
</script>
