---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  date: Date;
  minutesRead: number;
  tags: string[];
  cover?: ImageMetadata;
  coverAlt?: string;
}

const { title, description, slug, category, date, minutesRead, tags, cover, coverAlt = '' } = Astro.props;

const formattedDate = date.toLocaleDateString('es-ES', {
  day: '2-digit', month: 'short', year: 'numeric',
});
---

<a class="em-glass em-glass-hover card" href={`/articulos/${slug}`} data-glass>
  {cover && (
    <div class="cover">
      <Image src={cover} alt={coverAlt} width={600} height={375} />
    </div>
  )}
  <div class="body">
    <div class="em-meta">
      <span class="cat">{category}</span>
      <span class="dot"></span>
      <span>{formattedDate}</span>
      <span class="dot"></span>
      <span>{minutesRead} min</span>
    </div>
    <h3>{title}</h3>
    <p class="desc">{description}</p>
    <div class="footer">
      <div class="tags">
        {tags.slice(0, 2).map(tag => <span class="pill">{tag}</span>)}
      </div>
      <span class="read-link">Leer →</span>
    </div>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    position: relative;
  }
  .cover {
    aspect-ratio: 16/10;
    overflow: hidden;
    position: relative;
    border-bottom: 1px solid var(--color-em-border-2);
  }
  .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.9s var(--ease-out-em), filter 0.5s;
    filter: saturate(0.9);
  }
  .card:hover .cover :global(img) { transform: scale(1.06); filter: saturate(1.05); }

  .body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 19px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-em-fg-1);
    text-wrap: balance;
  }
  .desc { font-size: 13px; line-height: 1.55; color: var(--color-em-fg-3); }
  .footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 8px;
  }
  .tags { display: flex; gap: 6px; }
  .read-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-em-brand);
  }
</style>

<script>
  // Glass border effect — sigue el cursor
  document.querySelectorAll<HTMLElement>('[data-glass]').forEach(el => {
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const r = el.getBoundingClientRect();
      el.style.setProperty('--mx', (e.clientX - r.left) + 'px');
      el.style.setProperty('--my', (e.clientY - r.top) + 'px');
    });
  });
</script>
