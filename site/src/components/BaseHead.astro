---
import type { Locale } from '../lib/i18n';
import { getAlternatePath, getLocalizedPaths } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  alternateURL?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
  tags?: string[];
  locale?: Locale;
}

const {
  title,
  description,
  image = '/og-default.png',
  canonicalURL = Astro.url.href,
  alternateURL,
  noindex = false,
  type = 'website',
  publishedTime,
  modifiedTime,
  section,
  tags = [],
  locale = 'es',
} = Astro.props;

const isPrimaryBlogTitle = /^Blog\b/i.test(title) && /Edgar/i.test(title);
const siteTitle = isPrimaryBlogTitle ? title : `${title} · Edgar Martinez`;
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const umamiURL = import.meta.env.PUBLIC_UMAMI_URL
  ? new URL(import.meta.env.PUBLIC_UMAMI_URL, siteBase)
  : null;
const umamiOrigin = umamiURL?.origin;
const canonical = new URL(canonicalURL, siteBase).toString();
const inferredAlternate = getAlternatePath(Astro.url.pathname, '');
const alternateHref = new URL(alternateURL ?? inferredAlternate, siteBase).toString();
const ogLocale = locale === 'en' ? 'en_US' : 'es_ES';
const ogLocaleAlternate = locale === 'en' ? 'es_ES' : 'en_US';

const { rss } = getLocalizedPaths(locale);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{siteTitle}</title>
<meta name="title" content={siteTitle} />
<meta name="description" content={description} />
<meta name="author" content="Edgar Martinez Palmero" />
<meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'} />
<meta name="theme-color" content="#0a081d" />
<link rel="canonical" href={canonical} />
<link rel="preconnect" href={siteBase.origin} />
<link rel="dns-prefetch" href={siteBase.origin} />
{umamiOrigin && <link rel="preconnect" href={umamiOrigin} crossorigin />}
{umamiOrigin && <link rel="dns-prefetch" href={umamiOrigin} />}
<link rel="alternate" hrefLang={locale} href={canonical} />
<link rel="alternate" hrefLang={locale === 'en' ? 'es' : 'en'} href={alternateHref} />
<link rel="alternate" hrefLang="x-default" href={new URL('/', siteBase).toString()} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<meta property="og:type" content={type} />
<meta property="og:site_name" content="Blog · Edgar Martinez" />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={siteTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, siteBase)} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:locale:alternate" content={ogLocaleAlternate} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonical} />
<meta property="twitter:title" content={siteTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, siteBase)} />
<meta name="twitter:site" content="@edgarmartdev" />

{type === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === 'article' && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{type === 'article' && section && (
  <meta property="article:section" content={section} />
)}
{type === 'article' && tags.map(tag => (
  <meta property="article:tag" content={tag} />
))}

<link rel="alternate" type="application/rss+xml" title="Blog · Edgar Martinez" href={rss} />

{import.meta.env.PUBLIC_UMAMI_URL && import.meta.env.PUBLIC_UMAMI_WEBSITE_ID && (
  <script
    is:inline
    defer
    src={import.meta.env.PUBLIC_UMAMI_URL}
    data-website-id={import.meta.env.PUBLIC_UMAMI_WEBSITE_ID}
  />
)}

