---
import { Image } from 'astro:assets';
import ArticleCard from '../ArticleCard.astro';
import profileImg from '../../assets/profile.png';
import { getLocaleDateFormat, getLocalizedPaths, type Locale } from '../../lib/i18n';
import { getFeaturedAndLatest, getPublishedPosts, getReadingMinutes, withReadingMinutes } from '../../lib/blog';
import { homePageCopy } from '../../lib/ui-copy';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = homePageCopy[locale];
const paths = getLocalizedPaths(locale);

const allPosts = await getPublishedPosts(locale);
const { featured, latest } = getFeaturedAndLatest(allPosts, 3);
const featuredMinutes = featured ? await getReadingMinutes(featured) : 5;
const latestWithTime = await withReadingMinutes(latest);
const featuredDate = featured?.data.date.toLocaleDateString(getLocaleDateFormat(locale), {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
---

<main id="main-content" style="position:relative;z-index:1">
  <section class="hero">
    <div class="eyebrow">{copy.eyebrow}</div>
    <h1 class="hero-title">
      {copy.heroLead} <br />
      <em>{copy.heroName}</em>
    </h1>
    <p class="hero-sub">{copy.heroSub}</p>
    <div class="cta-row">
      <a class="btn btn-primary" href="#latest">
        {copy.latestCta} <span class="arr">→</span>
      </a>
      <a class="btn" href="https://edgarmartinez.dev" target="_blank" rel="noopener noreferrer">
        {copy.portfolioCta} <span class="arr">↗</span>
      </a>
    </div>
  </section>

  {featured && (
    <section class="em-container" id="featured">
      <a class="em-glass em-glass-hover featured" href={`${paths.articles}/${featured.id}`} data-glass>
        <span class="badge">{copy.featuredBadge}</span>
        {featured.data.cover && (
          <div class="cover">
            <Image
              src={featured.data.cover}
              alt={featured.data.coverAlt ?? ''}
              width={700}
              height={525}
              transition:name={`article-cover-${featured.id}`}
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
        )}
        <div class="body">
          <div class="em-meta">
            <span class="cat">{featured.data.category}</span>
            <span class="dot"></span>
            <span>{featuredDate}</span>
            <span class="dot"></span>
            <span>{featuredMinutes} {copy.featuredMinutesLabel}</span>
          </div>
          <h2>{featured.data.title}</h2>
          <p class="desc">{featured.data.description}</p>
          <div class="tags">
            {featured.data.tags.map(tag => <span class="pill">{tag}</span>)}
          </div>
          <div class="actions">
            <span class="btn btn-primary btn-sm">
              {copy.featuredRead} <span class="arr">→</span>
            </span>
          </div>
        </div>
      </a>
    </section>
  )}

  <section class="em-container" style="margin-top:96px" id="latest">
    <div class="section-eyebrow">
      {copy.latestSection}
      <a class="count-link" href={paths.articles}>{copy.viewAll} →</a>
    </div>
    {latestWithTime.length > 0 ? (
      <div class="cards-grid">
        {latestWithTime.map(({ post, minutes }) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            category={post.data.category}
            date={post.data.date}
            minutesRead={minutes}
            tags={post.data.tags}
            cover={post.data.cover}
            coverAlt={post.data.coverAlt}
            locale={locale}
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">{copy.noPosts}</p>
    )}
  </section>

  <section class="em-container" style="margin-top:96px" id="about-blog">
    <div class="section-eyebrow">{copy.aboutSection}</div>
    <div class="em-glass em-glass-hover about-block" data-glass>
      <div class="body">
        <span class="label hand">{copy.aboutHand}</span>
        <p>
          {copy.aboutTextStart}
          <strong>{copy.aboutTextStrong}</strong>
          {copy.aboutTextEnd}
        </p>
        <div class="actions">
          <a class="btn" href={paths.about}>
            {copy.aboutCta} <span class="arr">→</span>
          </a>
        </div>
      </div>
      <div class="portrait">
        <Image src={profileImg} alt={copy.heroName} width={480} height={600} />
      </div>
    </div>
  </section>
</main>

<style>
  .hero {
    max-width: var(--width-em-max);
    margin: 0 auto;
    padding: 160px 32px 96px;
    position: relative;
  }
  .hero .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-em-fg-4);
    margin-bottom: 32px;
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .hero .eyebrow::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--color-em-fg-5);
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: -0.045em;
    color: var(--color-em-fg-1);
    font-size: clamp(56px, 9vw, 132px);
    margin: 0;
    text-wrap: balance;
  }
  .hero-title em {
    font-style: italic;
    color: var(--color-em-brand);
    font-weight: 900;
    text-shadow: 0 0 32px var(--color-em-brand-soft);
  }
  .hero-sub {
    margin-top: 32px;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(17px, 1.4vw, 20px);
    line-height: 1.55;
    color: var(--color-em-fg-2);
    max-width: 62ch;
    text-wrap: pretty;
  }
  .cta-row {
    display: inline-flex;
    gap: 12px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  #featured {
    margin-top: 0;
  }
  .featured {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0;
    position: relative;
  }
  .featured .cover {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    border-right: 1px solid var(--color-em-border-2);
  }
  .featured .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.9s var(--ease-out-em), filter 0.5s;
    filter: saturate(0.95);
  }
  .featured:hover .cover :global(img) {
    transform: scale(1.04);
    filter: saturate(1.05);
  }
  .featured .cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 70%, rgba(18, 18, 21, 0.6) 100%);
    pointer-events: none;
  }
  .featured .badge {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 2;
    background: var(--color-em-brand);
    color: #0a081d;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }
  .featured .body {
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    justify-content: center;
  }
  .featured h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 2.4vw, 36px);
    line-height: 1.12;
    letter-spacing: -0.015em;
    color: var(--color-em-fg-1);
    text-wrap: balance;
  }
  .featured .desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-em-fg-3);
    max-width: 48ch;
  }
  .featured .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }
  .featured .actions {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: 8px;
  }

  .about-block {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 0;
    align-items: stretch;
  }
  .about-block .body {
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    justify-content: center;
  }
  .about-block .body .label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-em-brand);
  }
  .about-block .body .label.hand {
    font-family: var(--font-hand);
    font-size: 18px;
    letter-spacing: 0;
    text-transform: none;
    font-weight: 500;
  }
  .about-block .body p {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-em-fg-2);
    text-wrap: pretty;
    max-width: 50ch;
  }
  .about-block .body p strong {
    color: var(--color-em-fg-1);
    font-weight: 600;
  }
  .about-block .body .actions {
    margin-top: 8px;
    display: flex;
    gap: 12px;
  }
  .about-block .portrait {
    aspect-ratio: 4/5;
    position: relative;
    overflow: hidden;
    border-left: 1px solid var(--color-em-border-2);
  }
  .about-block .portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.7) brightness(0.92);
    transition: filter 0.8s var(--ease-out-em), transform 0.8s var(--ease-out-em);
  }
  .about-block:hover .portrait :global(img) {
    filter: grayscale(0) brightness(1);
    transform: scale(1.02);
  }

  .empty-state {
    margin-top: 20px;
    color: var(--color-em-fg-3);
    font-size: 14px;
  }

  @media (max-width: 960px) {
    .featured {
      grid-template-columns: 1fr;
    }
    .featured .cover {
      border-right: 0;
      border-bottom: 1px solid var(--color-em-border-2);
      aspect-ratio: 16/9;
    }
    .about-block {
      grid-template-columns: 1fr;
    }
    .about-block .portrait {
      border-left: 0;
      border-top: 1px solid var(--color-em-border-2);
      aspect-ratio: 16/10;
    }
  }
  @media (max-width: 640px) {
    .hero {
      padding: 120px 20px 80px;
    }
    .featured .body,
    .about-block .body {
      padding: 28px 24px;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-glass]').forEach(el => {
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const r = el.getBoundingClientRect();
      el.style.setProperty('--mx', e.clientX - r.left + 'px');
      el.style.setProperty('--my', e.clientY - r.top + 'px');
    });
  });
</script>
