---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import profileImg from '../../assets/profile.png';
import { getLocalePosts } from '../../lib/content';
import { getLocalizedPaths, type Locale } from '../../lib/i18n';
import { aboutPageCopy } from '../../lib/ui-copy';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = aboutPageCopy[locale];
const paths = getLocalizedPaths(locale);

const allEntries = await getCollection('blog', ({ data }) => !data.draft);
const allPosts = getLocalePosts(allEntries, locale);
const categories = [...new Set(allPosts.map(post => post.data.category))];
const sinceYear = allPosts.reduce((min, post) => Math.min(min, post.data.date.getFullYear()), new Date().getFullYear());
---

<main id="main-content" style="position:relative;z-index:1;padding-top:100px;padding-bottom:80px">
  <div class="em-container">
    <div class="page-header">
      <div class="section-eyebrow" style="margin-bottom:16px">{copy.headerEyebrow}</div>
      <h1>
        {copy.headerLine}<br /><em>{copy.headerEm}</em>
      </h1>
    </div>

    <div class="sobre-grid">
      <aside class="sidebar">
        <div class="profile-block em-glass">
          <div class="avatar">
            <Image src={profileImg} alt={copy.profileName} width={192} height={192} />
          </div>
          <span class="hola-text">hola 👋</span>
          <div class="profile-info">
            <strong>{copy.profileName}</strong>
            <span class="profile-role">{copy.profileRole}</span>
            <span class="profile-loc">{copy.profileLocation}</span>
            <p class="profile-bio">{copy.profileBio}</p>
          </div>

          <div class="link-rows">
            <a href="https://edgarmartinez.dev" target="_blank" rel="noopener noreferrer" class="link-row" data-umami-event="social_click" data-umami-location="about_portfolio">
              <span class="link-icon">🌐</span>
              <span class="link-label">{copy.portfolio}</span>
              <span class="link-arr">↗</span>
            </a>
            <a href="https://github.com/edgarmartinez" target="_blank" rel="noopener noreferrer" class="link-row" data-umami-event="social_click" data-umami-location="about_github">
              <span class="link-icon">⌥</span>
              <span class="link-label">{copy.github}</span>
              <span class="link-arr">↗</span>
            </a>
            <a href="https://linkedin.com/in/edgarmartinez" target="_blank" rel="noopener noreferrer" class="link-row" data-umami-event="social_click" data-umami-location="about_linkedin">
              <span class="link-icon">◈</span>
              <span class="link-label">{copy.linkedin}</span>
              <span class="link-arr">↗</span>
            </a>
            <a href="mailto:edgar@edgarmartinez.dev" class="link-row" data-umami-event="social_click" data-umami-location="about_email">
              <span class="link-icon">✉</span>
              <span class="link-label">{copy.email}</span>
              <span class="link-arr">→</span>
            </a>
          </div>
        </div>

        <div class="rss-block em-glass">
          <div class="rss-label">{copy.subscribe}</div>
          <div class="rss-pills">
            <a href={paths.rss} class="pill pill-rss" data-umami-event="rss_click" data-umami-location="about_rss">RSS Feed</a>
            <a href={paths.rss} class="pill" data-umami-event="rss_click" data-umami-location="about_atom">Atom</a>
            <a href={paths.rss} class="pill" data-umami-event="rss_click" data-umami-location="about_json_feed">JSON Feed</a>
          </div>
        </div>

        <div class="stats-block em-glass">
          <div class="stat">
            <span class="stat-num">{allPosts.length}</span>
            <span class="stat-label">{copy.statsArticles}</span>
          </div>
          <div class="stat-sep"></div>
          <div class="stat">
            <span class="stat-num">{categories.length}</span>
            <span class="stat-label">{copy.statsTopics}</span>
          </div>
          <div class="stat-sep"></div>
          <div class="stat">
            <span class="stat-num">{sinceYear}</span>
            <span class="stat-label">{copy.statsSince}</span>
          </div>
        </div>
      </aside>

      <article class="main-content">
        <div class="manifesto">
          {copy.manifesto.map(paragraph => <p>{paragraph}</p>)}
          <blockquote>{copy.quote}</blockquote>
        </div>

        <div class="faq-section">
          <div class="section-eyebrow" style="margin-bottom:28px">{copy.faqTitle}</div>
          {copy.faqItems.map(item => (
            <div class="faq-panel">
              <div class="faq-label">{item.label}</div>
              <p>{item.text}</p>
            </div>
          ))}
        </div>

        <div class="cta-block em-glass em-glass-hover" data-glass>
          <span class="cta-hand">{copy.ctaHand}</span>
          <p>{copy.ctaText}</p>
          <div class="cta-row">
            <a href={paths.articles} class="btn btn-primary" data-umami-event="cta_click" data-umami-location="about_articles_cta">
              {copy.ctaPrimary} <span class="arr">→</span>
            </a>
            <a href={paths.rss} class="btn" data-umami-event="rss_click" data-umami-location="about_rss_cta">{copy.ctaRss}</a>
          </div>
        </div>
      </article>
    </div>
  </div>
</main>

<style>
  .page-header {
    margin-bottom: 56px;
  }
  h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(28px, 3.5vw, 52px);
    letter-spacing: -0.03em;
    color: var(--color-em-fg-1);
    line-height: 1.1;
    max-width: 26ch;
  }
  h1 em {
    font-style: italic;
    color: var(--color-em-brand);
    font-weight: 900;
  }

  .sobre-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 56px;
    align-items: start;
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 92px;
  }

  .profile-block {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    border-radius: var(--radius-xl) !important;
  }
  .avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--color-em-border-2);
    flex-shrink: 0;
  }
  .avatar :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hola-text {
    font-family: var(--font-hand);
    font-size: 17px;
    color: var(--color-em-brand);
    font-weight: 500;
    margin-top: -4px;
  }

  .profile-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .profile-info strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    color: var(--color-em-fg-1);
  }
  .profile-role {
    font-size: 12px;
    color: var(--color-em-fg-3);
  }
  .profile-loc {
    font-size: 11px;
    color: var(--color-em-fg-5);
  }
  .profile-bio {
    font-size: 13px;
    color: var(--color-em-fg-4);
    line-height: 1.55;
    margin-top: 4px;
  }

  .link-rows {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-em-border-1);
    padding-top: 12px;
  }
  .link-row {
    display: grid;
    grid-template-columns: 20px 1fr auto;
    align-items: center;
    gap: 8px;
    padding: 9px 0;
    border-bottom: 1px solid var(--color-em-border-1);
    text-decoration: none;
    transition: color 0.2s;
    color: var(--color-em-fg-3);
    font-size: 13px;
  }
  .link-row:hover {
    color: var(--color-em-fg-1);
  }
  .link-icon {
    font-size: 13px;
    opacity: 0.6;
  }
  .link-label {
    flex: 1;
  }
  .link-arr {
    color: var(--color-em-fg-5);
    font-size: 12px;
    transition: transform 0.2s;
  }
  .link-row:hover .link-arr {
    transform: translateX(3px);
    color: var(--color-em-brand);
  }

  .rss-block {
    padding: 16px 20px;
    border-radius: var(--radius-xl) !important;
  }
  .rss-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-em-fg-5);
    margin-bottom: 10px;
  }
  .rss-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .pill-rss {
    background: rgba(220, 240, 93, 0.12) !important;
    color: var(--color-em-brand) !important;
    border-color: rgba(220, 240, 93, 0.25) !important;
  }

  .stats-block {
    padding: 16px 20px;
    border-radius: var(--radius-xl) !important;
    display: flex;
    align-items: center;
    gap: 0;
  }
  .stat {
    flex: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .stat-num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 22px;
    color: var(--color-em-fg-1);
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-em-fg-5);
  }
  .stat-sep {
    width: 1px;
    height: 36px;
    background: var(--color-em-border-1);
    flex-shrink: 0;
  }

  .main-content {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .manifesto {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .manifesto p {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(16px, 1.3vw, 19px);
    line-height: 1.6;
    color: var(--color-em-fg-2);
    max-width: 60ch;
    text-wrap: pretty;
  }
  .manifesto blockquote {
    margin: 8px 0 0;
    padding: 18px 24px;
    border-left: 3px solid var(--color-em-brand);
    background: rgba(220, 240, 93, 0.04);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    font-size: 16px;
    color: var(--color-em-fg-3);
    line-height: 1.5;
  }

  .faq-section {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .faq-panel {
    padding: 20px 24px;
    border: 1px solid var(--color-em-border-2);
    border-bottom: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .faq-panel:first-of-type {
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }
  .faq-panel:last-of-type {
    border-bottom: 1px solid var(--color-em-border-2);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  }
  .faq-panel:hover {
    background: rgba(255, 255, 255, 0.02);
    border-color: var(--color-em-border-3);
  }
  .faq-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-em-brand);
    margin-bottom: 8px;
  }
  .faq-panel p {
    font-size: 14px;
    color: var(--color-em-fg-3);
    line-height: 1.6;
    max-width: 62ch;
  }

  .cta-block {
    padding: 36px 40px;
    border-radius: var(--radius-xl) !important;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .cta-hand {
    font-family: var(--font-hand);
    font-size: 18px;
    color: var(--color-em-brand);
    font-weight: 500;
  }
  .cta-block p {
    font-size: 15px;
    color: var(--color-em-fg-3);
    max-width: 50ch;
    line-height: 1.55;
  }
  .cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  @media (max-width: 960px) {
    .sobre-grid {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
    }
  }
  @media (max-width: 640px) {
    .cta-block {
      padding: 24px;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-glass]').forEach(el => {
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const r = el.getBoundingClientRect();
      el.style.setProperty('--mx', e.clientX - r.left + 'px');
      el.style.setProperty('--my', e.clientY - r.top + 'px');
    });
  });
</script>
