---
import type { Locale } from '../lib/i18n';
import { getCollection } from 'astro:content';
import {
  LANG_LABEL,
  getAlternatePath,
  getLocaleFromPathname,
  getLocalizedPaths,
} from '../lib/i18n';
import { headerCopy } from '../lib/ui-copy';

interface Props {
  locale?: Locale;
}

const pathname = Astro.url.pathname;
const search = Astro.url.search;
const { locale = getLocaleFromPathname(pathname) } = Astro.props;
const paths = getLocalizedPaths(locale);
const copy = headerCopy[locale];

const articlesRoot = paths.articles;
const categoriesRoot = paths.categories;

const isActive = (path: string) => {
  if (path === paths.home) return pathname === path;
  return pathname.startsWith(path);
};

const currentHref = `${pathname}${search}`;
let alternateHref = getAlternatePath(pathname, search);

const articlePrefix = locale === 'en' ? '/en/articles/' : '/articulos/';
const isArticleDetail =
  pathname.startsWith(articlePrefix) &&
  pathname.length > articlePrefix.length &&
  pathname.slice(articlePrefix.length).split('/').filter(Boolean).length === 1;

if (isArticleDetail) {
  const slug = pathname.slice(articlePrefix.length).replace(/\/$/, '');
  const entries = await getCollection('blog', ({ data }) => !data.draft);
  const currentPost = entries.find(post =>
    post.id === slug && (locale === 'en' ? post.data.locale === 'en' : post.data.locale !== 'en')
  );

  if (currentPost?.data.translationKey) {
    const translatedPost = entries.find(post =>
      post.data.translationKey === currentPost.data.translationKey &&
      (locale === 'en' ? post.data.locale !== 'en' : post.data.locale === 'en')
    );

    if (translatedPost) {
      alternateHref =
        locale === 'en'
          ? `/articulos/${translatedPost.id}${search}`
          : `/en/articles/${translatedPost.id}${search}`;
    } else {
      alternateHref = locale === 'en' ? '/articulos' : '/en/articles';
    }
  }
}

const hrefEs = locale === 'es' ? currentHref : alternateHref;
const hrefEn = locale === 'en' ? currentHref : alternateHref;
---

<header class="em-header" id="site-header">
  <a class="brand" href={paths.home}>
    <span class="glyph" aria-hidden="true">+</span>
    Edgar Martinez
    <span class="muted">/ Blog</span>
  </a>
  <nav aria-label={copy.navAriaLabel}>
    <a
      href={paths.home}
      class:list={[{ active: isActive(paths.home) }]}
      aria-current={isActive(paths.home) ? 'page' : undefined}
    >
      {copy.home}
    </a>
    <a
      href={paths.articles}
      class:list={[{ active: isActive(articlesRoot) || isActive(categoriesRoot) }]}
      aria-current={isActive(articlesRoot) || isActive(categoriesRoot) ? 'page' : undefined}
    >
      {copy.articles}
    </a>
    <a
      href={paths.about}
      class:list={[{ active: isActive(paths.about) }]}
      aria-current={isActive(paths.about) ? 'page' : undefined}
    >
      {copy.about}
    </a>
    <span class="sep" aria-hidden="true"></span>
    <div class="lang-switch" role="group" aria-label={locale === 'en' ? 'Language selector' : 'Selector de idioma'}>
      <a
        class:list={['lang-link', { 'lang-active': locale === 'es' }]}
        href={hrefEs}
        aria-current={locale === 'es' ? 'true' : undefined}
        data-astro-reload=""
      >
        {LANG_LABEL.es}
      </a>
      <span class="lang-sep" aria-hidden="true">/</span>
      <a
        class:list={['lang-link', { 'lang-active': locale === 'en' }]}
        href={hrefEn}
        aria-current={locale === 'en' ? 'true' : undefined}
        data-astro-reload=""
      >
        {LANG_LABEL.en}
      </a>
    </div>
    <a class="ext" href="https://edgarmartinez.dev" target="_blank" rel="noopener noreferrer">
      {copy.portfolio} <span aria-hidden="true">↗</span>
    </a>
  </nav>
</header>

<style>
  .em-header {
    position: fixed;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 55;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 8px 8px 18px;
    background: rgba(26, 26, 30, 0.8);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-em-border-2);
    border-radius: var(--radius-pill);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    font-family: var(--font-body);
    white-space: nowrap;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-em-fg-1);
    padding-right: 6px;
  }

  .brand .glyph {
    display: inline-grid;
    place-items: center;
    width: 20px;
    height: 20px;
    border-radius: 5px;
    background: #121215;
    border: 1px solid var(--color-em-border-2);
    color: var(--color-em-brand);
    font-weight: 900;
    font-size: 11px;
  }

  .brand .muted {
    color: var(--color-em-fg-4);
    font-weight: 400;
    letter-spacing: 0;
  }

  nav {
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }

  nav a {
    position: relative;
    padding: 8px 12px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-em-fg-4);
    transition: color 0.3s;
    border-radius: var(--radius-pill);
  }

  nav a:hover {
    color: var(--color-em-fg-1);
  }

  nav a.active {
    color: var(--color-em-fg-1);
  }

  nav a.active::after {
    content: '';
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 2px;
    height: 2px;
    background: var(--color-em-brand);
    border-radius: 1px;
    box-shadow: 0 0 12px 2px var(--color-em-brand-soft);
  }

  .sep {
    width: 1px;
    height: 14px;
    background: var(--color-em-border-3);
    margin: 0 4px;
  }

  nav a.ext {
    color: var(--color-em-fg-3);
  }

  nav a.ext::after {
    display: none;
  }

  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0;
  }

  .lang-switch .lang-link {
    color: var(--color-em-fg-4);
    padding: 8px 4px;
  }

  .lang-switch .lang-link:hover {
    color: var(--color-em-fg-1);
  }

  .lang-switch .lang-link.lang-active {
    color: var(--color-em-brand);
  }

  .lang-switch .lang-link::after {
    display: none;
  }

  .lang-switch .lang-sep {
    color: var(--color-em-fg-5);
    font-size: 10px;
    line-height: 1;
    padding: 0 1px;
    user-select: none;
  }

  @media (max-width: 960px) {
    .em-header {
      font-size: 9px;
      padding: 6px 4px 6px 12px;
    }

    .brand .muted {
      display: none;
    }

    nav a {
      padding: 6px 8px;
    }

    .lang-switch {
      gap: 0;
    }

    .lang-switch .lang-link {
      padding: 6px 3px;
    }
  }
</style>
