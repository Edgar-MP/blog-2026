<style>
  .em-footer {
    position: relative;
    z-index: 1;
    margin-top: 120px;
    padding: 64px 0 40px;
    border-top: 1px solid var(--color-em-border-2);
    background: rgba(5, 5, 6, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .row {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 48px;
  }
  .sig {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    color: var(--color-em-fg-1);
    line-height: 1.4;
    letter-spacing: -0.01em;
  }
  .sig em { color: var(--color-em-brand); font-style: normal; }
  .loc { margin-top: 10px; font-size: 12px; color: var(--color-em-fg-4); }

  h6 {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--color-em-fg-5);
    text-transform: uppercase;
    margin-bottom: 14px;
    font-weight: 500;
  }
  ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  ul a {
    font-size: 13px;
    color: var(--color-em-fg-3);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.25s;
  }
  ul a:hover { color: var(--color-em-fg-1); }
  .ext { color: var(--color-em-fg-5); font-size: 11px; }

  .bottom {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-em-border-1);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-em-fg-5);
  }
  .heart { color: var(--color-em-brand); }

  @media (max-width: 960px) {
    .row { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 640px) {
    .row { grid-template-columns: 1fr; }
    .bottom { flex-direction: column; gap: 8px; text-align: center; }
  }
</style>
