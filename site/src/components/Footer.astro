---
import type { Locale } from '../lib/i18n';
import { getLocalizedPaths } from '../lib/i18n';
import { footerCopy } from '../lib/ui-copy';
import { getEditorialPolicyPath } from '../lib/site-identity';

interface Props {
  locale?: Locale;
}

const { locale = 'es' } = Astro.props;
const paths = getLocalizedPaths(locale);
const copy = footerCopy[locale];
const editorialPolicyPath = getEditorialPolicyPath(locale);
---

<footer class="em-footer">
  <div class="em-container">
    <div class="row">
      <div>
        <div class="sig">{copy.signature}<br /><em>{copy.signatureEm}</em></div>
        <div class="loc">{copy.location}</div>
      </div>

      <div>
        <h6>{copy.blog}</h6>
        <ul>
          <li><a href={paths.home}>{copy.home}</a></li>
          <li><a href={paths.articles}>{copy.articles}</a></li>
          <li><a href={paths.categories}>{copy.categories}</a></li>
          <li><a href={paths.about}>{copy.about}</a></li>
          <li>
            <a href={editorialPolicyPath}>
              {locale === 'en' ? 'Editorial policy' : 'Política editorial'}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h6>Edgar</h6>
        <ul>
          <li>
            <a href="https://edgarmartinez.dev" target="_blank" rel="noopener noreferrer">
              Portfolio <span class="ext">↗</span>
            </a>
          </li>
          <li>
            <a href="https://github.com/edgarmartinez" target="_blank" rel="noopener noreferrer">
              GitHub <span class="ext">↗</span>
            </a>
          </li>
          <li>
            <a href="https://linkedin.com/in/edgarmartinez" target="_blank" rel="noopener noreferrer">
              LinkedIn <span class="ext">↗</span>
            </a>
          </li>
          <li><a href="mailto:edgar@edgarmartinez.dev">Email</a></li>
        </ul>
      </div>

      <div>
        <h6>{copy.rss}</h6>
        <ul>
          <li><a href={paths.rss}>{copy.feed}</a></li>
        </ul>
      </div>
    </div>

    <div class="bottom">
      <span>{copy.bottomLeft}</span>
      <span>{copy.bottomRight}</span>
    </div>
  </div>
</footer>

<style>
  .em-footer {
    position: relative;
    z-index: 1;
    margin-top: 120px;
    padding: 64px 0 40px;
    border-top: 1px solid var(--color-em-border-2);
    background: rgba(5, 5, 6, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .row {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 48px;
  }

  .sig {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    color: var(--color-em-fg-1);
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .sig em {
    color: var(--color-em-brand);
    font-style: normal;
  }

  .loc {
    margin-top: 10px;
    font-size: 12px;
    color: var(--color-em-fg-4);
  }

  h6 {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--color-em-fg-5);
    text-transform: uppercase;
    margin-bottom: 14px;
    font-weight: 500;
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  ul a {
    font-size: 13px;
    color: var(--color-em-fg-3);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.25s;
  }

  ul a:hover {
    color: var(--color-em-fg-1);
  }

  .ext {
    color: var(--color-em-fg-5);
    font-size: 11px;
  }

  .bottom {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-em-border-1);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-em-fg-5);
  }

  @media (max-width: 960px) {
    .row {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 640px) {
    .row {
      grid-template-columns: 1fr;
    }

    .bottom {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }
</style>
