---
---

<canvas id="bg" aria-hidden="true"></canvas>

<script>
  // Sine-wave dot grid — port fiel de blog-particles.js (sin React, vanilla)
  (function () {
    const canvas = document.getElementById('bg') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d', { alpha: true })!;

    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0, h = 0;

    // grid
    const cols = 60;
    const rows = 40;
    interface Point { x: number; y: number; ox: number; oy: number; phase: number; }
    let points: Point[] = [];

    function buildPoints() {
      points = [];
      const cellW = w / (cols - 1);
      const cellH = h / (rows - 1);
      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          points.push({ x: x * cellW, y: y * cellH, ox: x * cellW, oy: y * cellH, phase: (x + y) * 0.18 });
        }
      }
    }

    function resize() {
      w = window.innerWidth;
      h = window.innerHeight;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      canvas!.style.width = w + 'px';
      canvas!.style.height = h + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      buildPoints();
    }

    let mx = -9999, my = -9999;
    window.addEventListener('mousemove', (e: MouseEvent) => { mx = e.clientX; my = e.clientY; });
    window.addEventListener('resize', resize);
    resize();

    // lee el color de acento de la variable CSS (usa --color-em-brand)
    function brandRGB(): [number, number, number] {
      const v = getComputedStyle(document.documentElement).getPropertyValue('--color-em-brand').trim() || '#dcf05d';
      const tmp = (document.createElement('canvas') as HTMLCanvasElement).getContext('2d')!;
      tmp.fillStyle = v;
      const hex = tmp.fillStyle as string; // normaliza a #rrggbb
      return [
        parseInt(hex.slice(1, 3), 16),
        parseInt(hex.slice(3, 5), 16),
        parseInt(hex.slice(5, 7), 16),
      ];
    }

    let t = 0;
    let running = true;
    let raf: number | null = null;

    function frame() {
      if (!running) return;
      t += 0.005;
      ctx.clearRect(0, 0, w, h);

      const [r, g, bl] = brandRGB();

      for (let i = 0; i < points.length; i++) {
        const p = points[i];
        // desplazamiento sinusoidal suave
        const dx = Math.sin(p.phase + t) * 6;
        const dy = Math.cos(p.phase * 0.7 + t * 1.2) * 6;

        // repulsión de ratón
        const ddx = p.ox + dx - mx;
        const ddy = p.oy + dy - my;
        const dist = Math.sqrt(ddx * ddx + ddy * ddy);
        let pushX = 0, pushY = 0;
        if (dist < 140) {
          const f = (1 - dist / 140) * 18;
          pushX = (ddx / dist) * f;
          pushY = (ddy / dist) * f;
        }

        const px = p.ox + dx + pushX;
        const py = p.oy + dy + pushY;

        // bandas de intensidad driven por ola lenta
        const wave = Math.sin(p.ox * 0.012 - t * 1.6 + p.oy * 0.006);
        const intensity = 0.18 + Math.max(0, wave) * 0.55;

        // brillo extra cerca del cursor
        const proximity = dist < 200 ? (1 - dist / 200) * 0.5 : 0;
        const a = Math.min(1, intensity + proximity);

        const size = 1 + (intensity > 0.5 ? 0.8 : 0);
        ctx.fillStyle = `rgba(${r},${g},${bl},${a * 0.7})`;
        ctx.fillRect(px - size / 2, py - size / 2, size, size);

        // destello blanco en los puntos más brillantes
        if (a > 0.85) {
          ctx.fillStyle = `rgba(255,255,255,${(a - 0.85) * 1.2})`;
          ctx.fillRect(px - 0.5, py - 0.5, 1, 1);
        }
      }

      raf = requestAnimationFrame(frame);
    }

    function start() { if (running) return; running = true; frame(); }
    function stop() { running = false; if (raf) cancelAnimationFrame(raf); }

    // toggle vía body[data-bg]
    const obs = new MutationObserver(() => {
      if ((document.body as HTMLElement).dataset.bg === 'off') stop();
      else if (!running) start();
    });
    obs.observe(document.body, { attributes: true, attributeFilter: ['data-bg'] });

    // pausa cuando la pestaña está oculta
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else if ((document.body as HTMLElement).dataset.bg !== 'off') start();
    });

    // Respeta prefers-reduced-motion
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (!mq.matches) frame();
  })();
</script>

<style>
  #bg {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    mask-image: linear-gradient(to bottom, #000 0%, #000 35%, transparent 90%);
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 35%, transparent 90%);
  }
</style>
