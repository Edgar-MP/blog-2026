---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import profileImg from '../assets/profile.webp';

// Obtener artículos publicados
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = allPosts.find(p => p.data.featured) ?? allPosts[0];
const latest = allPosts.filter(p => p.id !== featured?.id).slice(0, 3);

// Categorías únicas
const categories = [...new Set(allPosts.map(p => p.data.category))];

// Reading time de cada post
async function getMinutes(post: typeof allPosts[0]) {
  const { remarkPluginFrontmatter } = await render(post);
  return (remarkPluginFrontmatter?.minutesRead as number | undefined) ?? 5;
}

const featuredMinutes = featured ? await getMinutes(featured) : 5;
const latestWithTime = await Promise.all(
  latest.map(async p => ({ post: p, minutes: await getMinutes(p) }))
);

const featuredDate = featured?.data.date.toLocaleDateString('es-ES', {
  day: '2-digit', month: 'short', year: 'numeric',
});
---

<BaseLayout
  title="Blog · Edgar Martínez"
  description="Frontend, diseño y sistemas web desde la práctica. Aprendizajes, decisiones técnicas y experimentos."
>
  <!-- HERO -->
  <main style="position:relative;z-index:1">
    <section class="hero hero-medium">
      <div class="hero-content">
        <h1 class="hero-title">
          Notas sobre <em>frontend, diseño</em> y sistemas web
        </h1>
        <p class="hero-sub">
          Aprendizajes y decisiones técnicas desde la práctica.
        </p>
        <div class="cta-row">
          <a class="btn btn-primary" href="#latest">
            Leer artículos <span class="arr">→</span>
          </a>
          <a class="btn" href="https://edgarmartinez.dev" target="_blank" rel="noopener noreferrer">
            Portfolio <span class="arr">↗</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ARTÍCULO DESTACADO -->
    {featured && (
      <section class="em-container" id="featured">
        <div class="section-eyebrow">Artículo destacado</div>
        <a class="em-glass em-glass-hover featured" href={`/articulos/${featured.id}`} data-glass>
          <span class="badge">★ Destacado</span>
          {featured.data.cover && (
            <div class="cover">
              <Image src={featured.data.cover} alt={featured.data.coverAlt ?? ''} width={700} height={525} />
            </div>
          )}
          <div class="body">
            <div class="em-meta">
              <span class="cat">{featured.data.category}</span>
              <span class="dot"></span>
              <span>{featuredDate}</span>
              <span class="dot"></span>
              <span>{featuredMinutes} min lectura</span>
            </div>
            <h2>{featured.data.title}</h2>
            <p class="desc">{featured.data.description}</p>
            <div class="tags">
              {featured.data.tags.map(tag => <span class="pill">{tag}</span>)}
            </div>
            <div class="actions">
              <span class="btn btn-primary btn-sm">Leer artículo <span class="arr">→</span></span>
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- CATEGORÍAS -->
    <section class="em-container" style="margin-top:96px">
      <div class="section-eyebrow">
        Categorías
        <span class="count">{categories.length} temas</span>
      </div>
      <div class="cats">
        {categories.map((cat, i) => (
          <a
            class:list={['cat', { 'cat-active': i === 0 }]}
            href={`/categorias/${cat.toLowerCase().replace(/\s+/g, '-')}`}
          >
            {cat}
          </a>
        ))}
      </div>
    </section>

    <!-- ÚLTIMOS ARTÍCULOS -->
    <section class="em-container" style="margin-top:96px" id="latest">
      <div class="section-eyebrow">
        Últimos artículos
        <a class="count-link" href="/articulos">ver todos →</a>
      </div>
      <div class="cards-grid">
        {latestWithTime.map(({ post, minutes }) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            category={post.data.category}
            date={post.data.date}
            minutesRead={minutes}
            tags={post.data.tags}
            cover={post.data.cover}
            coverAlt={post.data.coverAlt}
          />
        ))}
      </div>
    </section>

    <!-- SOBRE ESTE BLOG -->
    <section class="em-container" style="margin-top:96px" id="about-blog">
      <div class="section-eyebrow">Sobre este blog</div>
      <div class="em-glass em-glass-hover about-block" data-glass>
        <div class="body">
          <span class="label hand">— notas, no documentación —</span>
          <p>
            Este blog es mi espacio para documentar aprendizajes, decisiones técnicas y experimentos relacionados
            con <strong>frontend, diseño de interfaces y desarrollo web</strong>. No pretende ser una
            documentación perfecta, sino una colección de notas útiles desde la práctica.
          </p>
          <div class="actions">
            <a class="btn" href="/sobre">Conocer más sobre mí <span class="arr">→</span></a>
          </div>
        </div>
        <div class="portrait">
          <Image src={profileImg} alt="Edgar Martínez" width={480} height={600} />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ── Hero (A·Medio) ── */
  .hero {
    max-width: var(--width-em-max);
    margin: 0 auto;
    padding: 0 32px;
    position: relative;
  }
  .hero-medium {
    display: flex;
    align-items: center;
    min-height: 40vh;
    padding-top: 80px;
    padding-bottom: 80px;
  }
  .hero-content {
    max-width: 54ch;
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: none;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-em-fg-1);
    font-size: clamp(32px, 5vw, 56px);
    margin: 0;
    text-wrap: pretty;
  }
  .hero-title em {
    font-style: italic;
    color: var(--color-em-brand);
    font-weight: 900;
  }
  .hero-sub {
    margin-top: 18px;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(15px, 1.1vw, 18px);
    line-height: 1.55;
    color: var(--color-em-fg-3);
    max-width: 48ch;
  }
  .cta-row { display: inline-flex; gap: 12px; margin-top: 28px; flex-wrap: wrap; }

  /* ── Featured card ── */
  .featured {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0;
    position: relative;
  }
  .featured .cover {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    border-right: 1px solid var(--color-em-border-2);
  }
  .featured .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.9s var(--ease-out-em), filter 0.5s;
    filter: saturate(0.95);
  }
  .featured:hover .cover :global(img) { transform: scale(1.04); filter: saturate(1.05); }
  .featured .cover::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 70%, rgba(18, 18, 21, 0.6) 100%);
    pointer-events: none;
  }
  .featured .badge {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 2;
    background: var(--color-em-brand);
    color: #0a081d;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }
  .featured .body {
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    justify-content: center;
  }
  .featured h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 2.4vw, 36px);
    line-height: 1.12;
    letter-spacing: -0.015em;
    color: var(--color-em-fg-1);
    text-wrap: balance;
  }
  .featured .desc { font-size: 15px; line-height: 1.6; color: var(--color-em-fg-3); max-width: 48ch; }
  .featured .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
  .featured .actions { display: flex; align-items: center; gap: 18px; margin-top: 8px; }

  /* ── About block ── */
  .about-block {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 0;
    align-items: stretch;
  }
  .about-block .body {
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    justify-content: center;
  }
  .about-block .body .label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-em-brand);
  }
  .about-block .body .label.hand {
    font-family: var(--font-hand);
    font-size: 18px;
    letter-spacing: 0;
    text-transform: none;
    font-weight: 500;
  }
  .about-block .body p {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-em-fg-2);
    text-wrap: pretty;
    max-width: 50ch;
  }
  .about-block .body p strong { color: var(--color-em-fg-1); font-weight: 600; }
  .about-block .body .actions { margin-top: 8px; display: flex; gap: 12px; }
  .about-block .portrait {
    aspect-ratio: 4/5;
    position: relative;
    overflow: hidden;
    border-left: 1px solid var(--color-em-border-2);
  }
  .about-block .portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.7) brightness(0.92);
    transition: filter 0.8s var(--ease-out-em), transform 0.8s var(--ease-out-em);
  }
  .about-block:hover .portrait :global(img) { filter: grayscale(0) brightness(1); transform: scale(1.02); }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .featured { grid-template-columns: 1fr; }
    .featured .cover { border-right: 0; border-bottom: 1px solid var(--color-em-border-2); aspect-ratio: 16/9; }
    .about-block { grid-template-columns: 1fr; }
    .about-block .portrait { border-left: 0; border-top: 1px solid var(--color-em-border-2); aspect-ratio: 16/10; }
  }
  @media (max-width: 640px) {
    .hero-medium { min-height: auto; padding-top: 60px; padding-bottom: 60px; }
    .featured .body, .about-block .body { padding: 28px 24px; }
  }
</style>

<script>
  // Glass border effect
  document.querySelectorAll<HTMLElement>('[data-glass]').forEach(el => {
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const r = el.getBoundingClientRect();
      el.style.setProperty('--mx', (e.clientX - r.left) + 'px');
      el.style.setProperty('--my', (e.clientY - r.top) + 'px');
    });
  });
</script>
