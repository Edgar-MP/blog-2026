---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLocalePosts } from '../../lib/content';
import { getLocalizedPaths } from '../../lib/i18n';

const locale = 'en';
const paths = getLocalizedPaths(locale);

const allEntries = await getCollection('blog', ({ data }) => !data.draft);
const allPosts = getLocalePosts(allEntries, locale);

const categories = [...new Set(allPosts.map(post => post.data.category))];
const sinceYear = allPosts.length
  ? Math.min(...allPosts.map(post => post.data.date.getFullYear()))
  : new Date().getFullYear();
---

<BaseLayout
  title="About this blog"
  description="Who writes this blog and what you can expect in the English edition."
  locale={locale}
>
  <main style="position:relative;z-index:1;padding-top:110px;padding-bottom:80px">
    <div class="em-container">
      <div class="page-header">
        <div class="section-eyebrow" style="margin-bottom:16px">About</div>
        <h1>Practical frontend notes,<br /><em>now in English.</em></h1>
      </div>

      <div class="content em-glass">
        <p>
          This is the English version of my blog. I share practical notes about frontend engineering,
          interface design, and design systems.
        </p>
        <p>
          The goal is simple: document real decisions, tradeoffs, and lessons learned while building products.
          Not polished tutorials, but useful field notes.
        </p>
        <div class="stats">
          <div>
            <strong>{allPosts.length}</strong>
            <span>English articles</span>
          </div>
          <div>
            <strong>{categories.length}</strong>
            <span>Topics</span>
          </div>
          <div>
            <strong>{sinceYear}</strong>
            <span>Since</span>
          </div>
        </div>

        <div class="cta-row">
          <a class="btn btn-primary" href={paths.articles}>Read articles <span class="arr">→</span></a>
          <a class="btn" href={paths.rss}>RSS Feed</a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(34px, 4.8vw, 64px);
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-em-fg-1);
  }

  h1 em {
    font-style: italic;
    color: var(--color-em-brand);
  }

  .content {
    padding: 34px;
    border-radius: var(--radius-xl) !important;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .content p {
    max-width: 64ch;
    color: var(--color-em-fg-2);
    line-height: 1.6;
  }

  .stats {
    margin-top: 8px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .stats div {
    border: 1px solid var(--color-em-border-2);
    border-radius: var(--radius-lg);
    padding: 14px;
    background: rgba(255, 255, 255, 0.02);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .stats strong {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--color-em-fg-1);
  }

  .stats span {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-em-fg-4);
  }

  .cta-row {
    margin-top: 8px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  @media (max-width: 760px) {
    .stats {
      grid-template-columns: 1fr;
    }
  }
</style>
