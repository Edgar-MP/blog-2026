---
import { getCollection } from 'astro:content';
import { getLocalePosts } from '../../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('blog', ({ data }) => !data.draft);
  const posts = getLocalePosts(entries, 'en');
  const categories = [...new Set(posts.map(p => p.data.category))];

  return categories.map(category => ({
    params: { cat: category.toLowerCase().replace(/\s+/g, '-') },
    props: { catSlug: category.toLowerCase().replace(/\s+/g, '-') },
  }));
}

const { catSlug } = Astro.props;
const target = `/en/articles?cat=${catSlug}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting...</title>
    <script define:vars={{ target }}>window.location.replace(target);</script>
  </head>
  <body>
    <p>Redirecting to <a href={target}>articles</a>...</p>
  </body>
</html>

