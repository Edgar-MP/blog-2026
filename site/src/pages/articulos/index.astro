---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { Image } from 'astro:assets';
import articlesOgImage from '../../assets/design-systems.png';
import { getLocaleDateFormat, getLocalizedPaths } from '../../lib/i18n';
import { getPublishedPosts, withReadingMinutes } from '../../lib/blog';

const locale = 'es';
const paths = getLocalizedPaths(locale);

const allPosts = await getPublishedPosts(locale);

const categories = [...new Set(allPosts.map(p => p.data.category))];

const postsWithTime = await withReadingMinutes(allPosts);
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: new URL('/', siteBase).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Artículos',
      item: new URL('/articulos', siteBase).toString(),
    },
  ],
};
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: allPosts.slice(0, 20).map((post, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: new URL(`${paths.articles}/${post.id}`, siteBase).toString(),
    name: post.data.title,
  })),
};
---

<BaseLayout
  title="Artículos"
  description="Todos los artículos sobre frontend, diseño, Astro, design systems y más."
  image={articlesOgImage.src}
  locale={locale}
  structuredData={[breadcrumbSchema, itemListSchema]}
>
  <main id="main-content" style="position:relative;z-index:1;padding-top:120px;padding-bottom:80px">
    <div class="em-container">

      <!-- Page header -->
      <div class="page-header">
        <div class="section-eyebrow" style="margin-bottom:16px">Artículos</div>
        <h1 id="page-title">Todos los <em>artículos</em></h1>
        <p class="sub" id="post-count">{allPosts.length} publicaciones · ordenadas por fecha</p>
      </div>

      <!-- Filter bar (L·02) -->
      <div class="filter-wrap">
        <div class="filter-line"></div>
        <nav class="filter-bar" aria-label="Filtrar por categoría">
          <div class="filter-pills">
            <button class="cat cat-all cat-active" data-cat="" aria-pressed="true">Todos</button>
            {categories.map(cat => (
              <button
                class="cat"
                data-cat={cat.toLowerCase().replace(/\s+/g, '-')}
                data-label={cat}
                aria-pressed="false"
              >{cat}</button>
            ))}
          </div>
          <div class="filter-actions">
            <label class="search-control" for="article-search">
              <span class="search-hint">Buscar <kbd id="search-shortcut">Ctrl K</kbd></span>
              <input id="article-search" type="search" placeholder="Titulo, descripcion o tag" autocomplete="off" />
            </label>
            <label class="sort-control" for="sort-order">
              <span class="sort-hint">Ordenar por</span>
              <select id="sort-order">
                <option value="recent">Mas reciente</option>
                <option value="oldest">Mas antiguo</option>
                <option value="title">Titulo A-Z</option>
              </select>
            </label>
          </div>
        </nav>
        <div class="filter-line"></div>
      </div>

      <!-- Category blurb (visible sólo en modo filtro) -->
      <div class="cat-blurb" id="cat-blurb" hidden>
        <span class="cat-blurb-hand" id="cat-blurb-name"></span>
        <p class="cat-blurb-sub">
          Artículos sobre <strong id="cat-blurb-label"></strong> — técnicas, aprendizajes y experimentos desde la práctica.
        </p>
        <span class="cat-blurb-count" id="cat-blurb-count"></span>
        <button class="cat-clear" id="cat-clear" aria-label="Quitar filtro">× ver todos</button>
      </div>

      <!-- Grid (modo todos) -->
      <div class="articles-grid" id="articles-grid">
        {postsWithTime.map(({ post, minutes }) => (
          <div
            data-cat-item={post.data.category.toLowerCase().replace(/\s+/g, '-')}
            data-date={post.data.date.getTime().toString()}
            data-title={post.data.title.toLowerCase()}
            data-search={`${post.data.title} ${post.data.description} ${post.data.tags.join(' ')} ${post.data.category}`.toLowerCase()}
          >
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              slug={post.id}
              category={post.data.category}
              date={post.data.date}
              minutesRead={minutes}
              tags={post.data.tags}
              cover={post.data.cover}
              coverAlt={post.data.coverAlt}
              locale={locale}
            />
          </div>
        ))}
      </div>

      <!-- Lista (modo filtro por categoría — C·03) -->
      <div class="articles-list" id="articles-list" hidden>
        {postsWithTime.map(({ post, minutes }) => (
          <a
            class="list-row"
            href={`${paths.articles}/${post.id}`}
            data-cat-item={post.data.category.toLowerCase().replace(/\s+/g, '-')}
            data-date={post.data.date.getTime().toString()}
            data-title={post.data.title.toLowerCase()}
            data-search={`${post.data.title} ${post.data.description} ${post.data.tags.join(' ')} ${post.data.category}`.toLowerCase()}
            hidden
          >
            <time class="list-date" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString(getLocaleDateFormat(locale), { day: '2-digit', month: 'short', year: 'numeric' })}
            </time>
            <div class="list-cover">
              {post.data.cover
                ? <Image src={post.data.cover} alt={post.data.coverAlt ?? ''} width={80} height={56} />
                : <div class="list-cover-empty"></div>
              }
            </div>
            <div class="list-body">
              <span class="list-cat">{post.data.category}</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </div>
            <div class="list-time">{minutes} min <span class="arr">→</span></div>
          </a>
        ))}
      </div>

    </div>
  </main>
</BaseLayout>

<style>
  .page-header { margin-bottom: 40px; }
  h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(40px, 5vw, 72px);
    text-transform: uppercase;
    letter-spacing: -0.04em;
    color: var(--color-em-fg-1);
    line-height: 1;
    margin-bottom: 12px;
  }
  h1 em { font-style: italic; color: var(--color-em-brand); }
  .sub { font-size: 13px; color: var(--color-em-fg-4); font-family: var(--font-mono); letter-spacing: 0.1em; }

  /* Filter bar */
  .filter-wrap { margin-bottom: 48px; }
  .filter-line { height: 1px; background: var(--color-em-border-1); }
  .filter-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 0;
    flex-wrap: wrap;
  }
  .filter-pills { display: flex; flex-wrap: wrap; gap: 6px; }

  /* Filter pills — botones de categoría */
  .filter-bar .cat {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    border: 1px solid var(--color-em-border-2);
    background: rgba(255,255,255,0.02);
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-em-fg-3);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    letter-spacing: 0.02em;
  }
  .filter-bar .cat:hover {
    color: var(--color-em-fg-1);
    border-color: var(--color-em-border-3);
    background: rgba(255,255,255,0.04);
  }
  .filter-bar .cat.cat-active {
    color: var(--color-em-bg);
    background: var(--color-em-brand);
    border-color: var(--color-em-brand);
    font-weight: 600;
  }
  .filter-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }
  .search-control,
  .sort-control {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .search-control input,
  .sort-control select {
    height: 30px;
    border: 1px solid var(--color-em-border-2);
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-em-fg-2);
    font-family: var(--font-body);
    font-size: 12px;
    padding: 0 12px;
  }
  .search-control input {
    width: 220px;
  }
  .sort-control select {
    min-width: 140px;
    cursor: pointer;
  }
  .search-control input:focus,
  .sort-control select:focus {
    outline: none;
    border-color: var(--color-em-brand);
    box-shadow: 0 0 0 2px rgba(220, 240, 93, 0.2);
  }
  .search-hint {
    font-size: 12px;
    color: var(--color-em-fg-5);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
  }
  .search-hint kbd {
    display: inline-flex;
    align-items: center;
    padding: 2px 6px;
    border: 1px solid var(--color-em-border-2);
    border-radius: var(--radius-sm);
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--color-em-fg-4);
    background: rgba(255,255,255,0.03);
  }
  .sort-hint {
    font-size: 12px;
    color: var(--color-em-fg-5);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  /* Category blurb (C·03) */
  .cat-blurb {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px 32px;
    border-radius: var(--radius-xl);
    background: linear-gradient(135deg, rgba(220,240,93,0.08) 0%, rgba(220,240,93,0.03) 100%);
    border: 1px solid rgba(220,240,93,0.2);
    margin-bottom: 40px;
  }
  .cat-blurb[hidden] { display: none; }
  .cat-blurb-hand {
    font-family: var(--font-hand);
    font-size: 22px;
    color: var(--color-em-brand);
    font-weight: 500;
  }
  .cat-blurb-sub {
    font-size: 15px;
    color: var(--color-em-fg-3);
    max-width: 54ch;
    line-height: 1.5;
  }
  .cat-blurb-sub strong { color: var(--color-em-fg-1); font-weight: 600; }
  .cat-blurb-count {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--color-em-fg-5);
    text-transform: uppercase;
  }
  .cat-clear {
    align-self: flex-start;
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--color-em-fg-4);
    border: 1px solid var(--color-em-border-2);
    border-radius: var(--radius-pill);
    padding: 4px 12px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    background: transparent;
  }
  .cat-clear:hover { color: var(--color-em-fg-1); border-color: var(--color-em-border-3); }

  /* Grid (2-col default) */
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .articles-grid[hidden] { display: none; }
  .articles-grid > div { display: contents; }

  /* List view (C·03 filtered) */
  .articles-list { display: flex; flex-direction: column; }
  .articles-list[hidden] { display: none; }

  .list-row {
    display: grid;
    grid-template-columns: 100px 88px 1fr auto;
    gap: 20px;
    align-items: center;
    padding: 18px 0;
    border-bottom: 1px solid var(--color-em-border-1);
    text-decoration: none;
    transition: background 0.2s;
    border-radius: var(--radius-sm);
  }
  .list-row:first-child { border-top: 1px solid var(--color-em-border-1); }
  .list-row:hover { background: rgba(255,255,255,0.02); }
  .list-row[hidden] { display: none; }

  .list-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-em-fg-5);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.3;
  }
  .list-cover {
    width: 80px;
    height: 56px;
    border-radius: var(--radius-md);
    overflow: hidden;
    flex-shrink: 0;
  }
  .list-cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.9);
    transition: filter 0.3s;
  }
  .list-row:hover .list-cover :global(img) { filter: saturate(1.1); }
  .list-cover-empty {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-em-border-2), var(--color-em-border-1));
  }
  .list-body { min-width: 0; display: flex; flex-direction: column; gap: 4px; }
  .list-cat {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-em-brand);
  }
  .list-body h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: var(--color-em-fg-1);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .list-row:hover .list-body h3 { color: var(--color-em-brand); }
  .list-body p {
    font-size: 12px;
    color: var(--color-em-fg-4);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .list-time {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-em-fg-4);
    white-space: nowrap;
    transition: color 0.2s;
  }
  .list-row:hover .list-time { color: var(--color-em-brand); }
  .list-time .arr { transition: transform 0.2s; display: inline-block; }
  .list-row:hover .list-time .arr { transform: translateX(4px); }

  @media (max-width: 960px) {
    .list-row { grid-template-columns: 80px 1fr auto; }
    .list-cover { display: none; }
  }
  @media (max-width: 640px) {
    .articles-grid { grid-template-columns: 1fr; }
    .list-row { grid-template-columns: 1fr auto; }
    .list-date { display: none; }
    .filter-actions { display: none; }
  }
</style>

<script>
  const grid = document.getElementById('articles-grid') as HTMLElement;
  const list = document.getElementById('articles-list') as HTMLElement;
  const blurb = document.getElementById('cat-blurb') as HTMLElement;
  const blurbName = document.getElementById('cat-blurb-name') as HTMLElement;
  const blurbLabel = document.getElementById('cat-blurb-label') as HTMLElement;
  const blurbCount = document.getElementById('cat-blurb-count') as HTMLElement;
  const catClear = document.getElementById('cat-clear') as HTMLButtonElement;
  const postCount = document.getElementById('post-count') as HTMLElement;
  const pageTitle = document.getElementById('page-title') as HTMLElement;
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-bar .cat');
  const sortOrder = document.getElementById('sort-order') as HTMLSelectElement;
  const searchInput = document.getElementById('article-search') as HTMLInputElement;
  const searchShortcut = document.getElementById('search-shortcut') as HTMLElement;

  const current = {
    category: '',
    query: '',
  };

  if (searchShortcut) {
    const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform);
    searchShortcut.textContent = isMac ? 'Cmd K' : 'Ctrl K';
  }

  function sortItems(container: HTMLElement) {
    const items = Array.from(container.querySelectorAll<HTMLElement>('[data-cat-item]'));
    const order = sortOrder?.value ?? 'recent';

    items.sort((a, b) => {
      const aDate = Number(a.dataset.date ?? '0');
      const bDate = Number(b.dataset.date ?? '0');
      const aTitle = a.dataset.title ?? '';
      const bTitle = b.dataset.title ?? '';

      if (order === 'oldest') return aDate - bDate;
      if (order === 'title') return aTitle.localeCompare(bTitle, 'es');
      return bDate - aDate;
    });

    items.forEach(item => container.appendChild(item));
  }

  function countVisibleItems(container: HTMLElement): number {
    return Array.from(container.querySelectorAll<HTMLElement>('[data-cat-item]')).filter(item => !item.hidden).length;
  }

  function applyVisibility() {
    const query = current.query.trim().toLowerCase();
    const category = current.category;

    const updateItems = (items: NodeListOf<HTMLElement>, allowCategory: boolean) => {
      items.forEach(item => {
        const matchesCategory = !category || item.dataset.catItem === category;
        const haystack = item.dataset.search ?? '';
        const matchesQuery = !query || haystack.includes(query);
        const matches = (allowCategory ? matchesCategory : !category) && matchesQuery;
        item.hidden = !matches;
      });
    };

    if (!category) {
      grid.hidden = false;
      list.hidden = true;
      blurb.hidden = true;

      updateItems(grid.querySelectorAll<HTMLElement>('[data-cat-item]'), false);
      const visible = countVisibleItems(grid);
      postCount.textContent = `${visible} publicaciones · ordenadas por fecha`;
      pageTitle.innerHTML = 'Todos los <em>articulos</em>';
      return;
    }

    const activeBtn = document.querySelector<HTMLButtonElement>(`.filter-bar .cat[data-cat="${category}"]`);
    const label = activeBtn?.dataset.label ?? category;

    grid.hidden = true;
    list.hidden = false;

    updateItems(list.querySelectorAll<HTMLElement>('[data-cat-item]'), true);
    const visible = countVisibleItems(list);

    blurbName.textContent = label;
    blurbLabel.textContent = label;
    blurbCount.textContent = `${visible} articulo${visible === 1 ? '' : 's'}`;
    blurb.hidden = false;

    postCount.textContent = `${visible} articulo${visible === 1 ? '' : 's'} en ${label}`;
    pageTitle.innerHTML = `<em>${label}</em>`;
  }

  function syncUrlCategory() {
    const url = new URL(window.location.href);
    if (current.category) {
      url.searchParams.set('cat', current.category);
    } else {
      url.searchParams.delete('cat');
    }
    window.history.replaceState({}, '', url.toString());
  }

  function syncPills() {
    pills.forEach(p => {
      const isActive = p.dataset.cat === current.category;
      p.classList.toggle('cat-active', isActive);
      p.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    });
  }

  function render() {
    sortItems(grid);
    sortItems(list);
    syncPills();
    syncUrlCategory();
    applyVisibility();
  }

  pills.forEach(btn => {
    btn.addEventListener('click', () => {
      current.category = btn.dataset.cat ?? '';
      render();
    });
  });

  catClear.addEventListener('click', () => {
    current.category = '';
    render();
  });

  if (sortOrder) {
    sortOrder.addEventListener('change', () => render());
  }

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      current.query = searchInput.value;
      applyVisibility();
    });
  }

  document.addEventListener('keydown', event => {
    if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
      event.preventDefault();
      searchInput?.focus();
      searchInput?.select();
    }
  });

  const initCat = new URL(window.location.href).searchParams.get('cat') ?? '';
  if (initCat) {
    current.category = initCat;
  }

  render();
</script>
