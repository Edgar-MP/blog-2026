---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ParticlesBg from '../components/ParticlesBg.astro';
import ViewTransitions from '../components/ViewTransitions.astro';
import type { Locale } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  structuredData?: unknown | unknown[];
  locale?: Locale;
}

const { title, description, image, noindex = false, structuredData, locale = 'es' } = Astro.props;
const siteBase = Astro.site ?? new URL(Astro.url.origin);
const homePath = locale === 'en' ? '/en' : '/';
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': new URL(`${homePath}#website`, siteBase).toString(),
  url: new URL(homePath, siteBase).toString(),
  name: 'Blog · Edgar Martinez',
  description,
  inLanguage: locale,
};
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': new URL('/#edgar-martinez-palmero', siteBase).toString(),
  name: 'Edgar Martinez Palmero',
  url: 'https://edgarmartinez.dev',
  jobTitle: 'Frontend Developer',
  sameAs: [
    'https://github.com/edgarmartinez',
    'https://linkedin.com/in/edgarmartinez',
  ],
};
const pageSchemas = structuredData
  ? (Array.isArray(structuredData) ? structuredData : [structuredData])
  : [];
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead title={title} description={description} image={image} noindex={noindex} locale={locale} />
    <script type="application/ld+json" set:html={JSON.stringify([websiteSchema, personSchema])} />
    {pageSchemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <ViewTransitions />
  </head>
  <body>
    <a class="skip-link" href="#main-content">
      {locale === 'en' ? 'Skip to main content' : 'Saltar al contenido principal'}
    </a>
    <ParticlesBg />
    <Header locale={locale} />
    <slot />
    <Footer locale={locale} />
  </body>
</html>
