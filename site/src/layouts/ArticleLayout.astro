---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ParticlesBg from '../components/ParticlesBg.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  tags: string[];
  minutesRead: number;
  cover?: ImageMetadata;
  coverAlt?: string;
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
}

const { title, description, date, category, tags, minutesRead, cover, coverAlt = '', headings, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('es-ES', {
  day: '2-digit', month: 'short', year: 'numeric',
}).toUpperCase();

const catSlug = category.toLowerCase().replace(/\s+/g, '-');

// Artículos relacionados por categoría o tags
const allPosts = await getCollection('blog', p => !p.data.draft && p.id !== slug);
const related = allPosts
  .filter(p => p.data.category === category || p.data.tags.some(t => tags.includes(t)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <ParticlesBg />
    <Header />

    <!-- Barra de progreso de lectura (top fixed) -->
    <div class="reading-progress-bar" id="reading-progress" aria-hidden="true"></div>

    <main style="position:relative;z-index:1">
      <div class="em-container">

        <!-- ← Volver a artículos -->
        <a href="/articulos" class="back-link">← Volver a artículos</a>

        <!-- Hero section -->
        <section class="hero-section">

          <!-- Cover 21:9 dentro del container, radius xl, sin efectos -->
          {cover && (
            <div class="cover-wrap">
              <Image src={cover} alt={coverAlt} width={1440} height={620} class="cover-img" />
            </div>
          )}

          <!-- Meta + título + descripción + tags, centrados -->
          <div class={cover ? 'hero-content' : 'hero-content no-cover'}>
            <div class="hero-meta">
              <a href={`/articulos?cat=${catSlug}`} class="hero-cat">{category.toUpperCase()}</a>
              <span class="hero-sep">·</span>
              <span>{formattedDate}</span>
              <span class="hero-sep">·</span>
              <span>{minutesRead} MIN</span>
            </div>
            <h1>{title}</h1>
            <p class="hero-desc">{description}</p>
            <div class="tags-row">
              {tags.map(tag => <span class="pill">{tag}</span>)}
            </div>
          </div>
        </section>

        <!-- Divisor punteado -->
        <div class="divider-dashed"></div>

        <!-- Grid: TOC + Prose -->
        <div class="article-body">
          <aside class="toc-col">
            <TableOfContents headings={headings} />
          </aside>
          <article class="prose-em">
            <slot />
          </article>
        </div>

        <!-- Author CTA inline (centrado, max-width 680px) -->
        <div class="author-cta">
          <div class="author-avatar"></div>
          <div class="author-info">
            <strong>Edgar Martínez Palmero</strong>
            <p>Frontend developer en Vitoria-Gasteiz. Diseño y construyo interfaces.</p>
          </div>
          <a href="https://edgarmartinez.dev" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">
            Ver portfolio <span class="arr">↗</span>
          </a>
        </div>

        <!-- Seguir leyendo -->
        {related.length > 0 && (
          <section class="related-section">
            <div class="section-eyebrow">Seguir leyendo</div>
            <div class="related-grid" style={`grid-template-columns: repeat(${Math.min(related.length, 3)}, 1fr)`}>
              {related.map(post => (
                <a class="em-glass em-glass-hover related-card" href={`/articulos/${post.id}`} data-glass>
                  <div class="related-body">
                    <div class="em-meta">
                      <span class="cat">{post.data.category}</span>
                      <span class="dot"></span>
                      <span>{post.data.date.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })}</span>
                    </div>
                    <h4>{post.data.title}</h4>
                    <p>{post.data.description}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  /* ── Progreso top ─────────────────────────────────────────────────── */
  .reading-progress-bar {
    position: fixed;
    top: 0; left: 0;
    height: 2px;
    width: 0%;
    background: var(--color-em-brand);
    z-index: 200;
    transition: width 0.1s linear;
    box-shadow: 0 0 8px var(--color-em-brand-soft);
  }

  /* ── Volver ───────────────────────────────────────────────────────── */
  .back-link {
    display: inline-block;
    padding-top: 100px;
    padding-bottom: 24px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-em-fg-4);
    text-decoration: none;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-em-fg-1); }

  /* ── Hero ─────────────────────────────────────────────────────────── */
  .hero-section {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Cover — dentro del container, sin efectos, radius xl */
  .cover-wrap {
    width: 100%;
    aspect-ratio: 21 / 9;
    overflow: hidden;
    border-radius: var(--radius-xl);
  }
  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* sin filter, sin overlay — imagen limpia */
  }

  /* Texto del hero, centrado */
  .hero-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .hero-content.no-cover { padding-top: 32px; }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-em-fg-4);
    letter-spacing: 0.15em;
  }
  .hero-cat {
    color: var(--color-em-brand);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .hero-cat:hover { opacity: 0.8; }
  .hero-sep { color: var(--color-em-fg-5); }

  .hero-content h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(40px, 4.5vw, 54px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-em-fg-1);
    text-wrap: balance;
    max-width: 18ch;
    margin: 0;
  }
  .hero-desc {
    font-size: 18px;
    color: var(--color-em-fg-3);
    line-height: 1.5;
    max-width: 38ch;
    margin: 0;
    text-wrap: pretty;
  }
  .tags-row { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }

  /* ── Divisor punteado ─────────────────────────────────────────────── */
  .divider-dashed {
    margin-top: 64px;
    border-top: 1px dashed var(--color-em-border-2);
    margin-bottom: 48px;
  }

  /* ── Grid TOC + Prose ─────────────────────────────────────────────── */
  .article-body {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 64px;
    align-items: start;
    padding-bottom: 80px;
  }
  .toc-col { display: block; }

  /* ── Author CTA inline ────────────────────────────────────────────── */
  .author-cta {
    max-width: 680px;
    margin: 0 auto 64px;
    padding: 24px;
    border: 1px solid var(--color-em-border-2);
    border-radius: var(--radius-xl);
    background: var(--color-em-surface);
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .author-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-em-border-3), var(--color-em-border-1));
    flex-shrink: 0;
  }
  .author-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .author-info strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    color: var(--color-em-fg-1);
  }
  .author-info p {
    font-size: 13px;
    color: var(--color-em-fg-3);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Seguir leyendo ───────────────────────────────────────────────── */
  .related-section { padding-bottom: 80px; }
  .related-grid {
    display: grid;
    gap: 16px;
    margin-top: 24px;
  }
  .related-card { border-radius: var(--radius-xl) !important; }
  .related-body { padding: 24px; display: flex; flex-direction: column; gap: 10px; }
  .related-card h4 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    line-height: 1.3;
    color: var(--color-em-fg-1);
    transition: color 0.2s;
  }
  .related-card:hover h4 { color: var(--color-em-brand); }
  .related-card p { font-size: 13px; color: var(--color-em-fg-3); line-height: 1.5; }

  /* ── Responsive ───────────────────────────────────────────────────── */
  @media (max-width: 960px) {
    .article-body { grid-template-columns: 1fr; }
    .toc-col { display: none; }
    .cover-wrap { aspect-ratio: 16 / 9; }
  }
  @media (max-width: 640px) {
    .back-link { padding-top: 80px; }
    .hero-content h1 { font-size: clamp(32px, 8vw, 44px); }
    .hero-desc { font-size: 16px; }
    .author-cta { flex-wrap: wrap; }
    .author-cta .btn { width: 100%; justify-content: center; }
  }
</style>

<script>
  // Glass border effect en cards relacionadas
  document.querySelectorAll<HTMLElement>('[data-glass]').forEach(el => {
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const r = el.getBoundingClientRect();
      el.style.setProperty('--mx', (e.clientX - r.left) + 'px');
      el.style.setProperty('--my', (e.clientY - r.top) + 'px');
    });
  });

  // Progress bar top
  const bar = document.getElementById('reading-progress') as HTMLElement | null;
  if (bar) {
    function updateBar() {
      const pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
      bar!.style.width = Math.min(100, pct) + '%';
    }
    window.addEventListener('scroll', updateBar, { passive: true });
  }
</script>
