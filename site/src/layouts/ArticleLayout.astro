---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ParticlesBg from '../components/ParticlesBg.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ViewTransitions from '../components/ViewTransitions.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { Locale } from '../lib/i18n';
import { getLocaleDateFormat, getLocalizedPaths } from '../lib/i18n';
import { getLocalePosts } from '../lib/content';
import { articleUiCopy } from '../lib/ui-copy';

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  tags: string[];
  minutesRead: number;
  cover?: ImageMetadata;
  coverAlt?: string;
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
  translationKey?: string;
  locale?: Locale;
}

const {
  title,
  description,
  date,
  category,
  tags,
  minutesRead,
  cover,
  coverAlt = '',
  headings,
  slug,
  translationKey,
  locale = 'es',
} = Astro.props;

const copy = articleUiCopy[locale];

const paths = getLocalizedPaths(locale);
const formattedDate = date
  .toLocaleDateString(getLocaleDateFormat(locale), {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  })
  .toUpperCase();

const catSlug = category.toLowerCase().replace(/\s+/g, '-');

const allEntries = await getCollection('blog', p => !p.data.draft);
const allPosts = allEntries.filter(post => post.id !== slug);
const related = getLocalePosts(allPosts, locale)
  .filter(p => p.data.category === category || p.data.tags.some(t => tags.includes(t)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const alternatePost = translationKey
  ? allEntries.find(post =>
      post.data.translationKey === translationKey &&
      (locale === 'en' ? post.data.locale !== 'en' : post.data.locale === 'en')
    )
  : undefined;
const alternateURL = alternatePost
  ? locale === 'en'
    ? `/articulos/${alternatePost.id}`
    : `/en/articles/${alternatePost.id}`
  : undefined;

const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.href, siteBase).toString();
const articleImage = cover ? new URL(cover.src, siteBase).toString() : undefined;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  inLanguage: locale,
  mainEntityOfPage: canonical,
  url: canonical,
  author: {
    '@type': 'Person',
    name: 'Edgar Martinez Palmero',
    url: 'https://edgarmartinez.dev',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Edgar Martinez',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', siteBase).toString(),
    },
  },
  articleSection: category,
  keywords: tags.join(', '),
  ...(articleImage ? { image: [articleImage] } : {}),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: locale === 'en' ? 'Home' : 'Inicio',
      item: new URL(paths.home, siteBase).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: locale === 'en' ? 'Articles' : 'Artículos',
      item: new URL(paths.articles, siteBase).toString(),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: canonical,
    },
  ],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={cover?.src}
      type="article"
      publishedTime={date.toISOString()}
      modifiedTime={date.toISOString()}
      section={category}
      tags={tags}
      locale={locale}
      alternateURL={alternateURL}
    />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <ViewTransitions />
  </head>
  <body>
    <a class="skip-link" href="#main-content">
      {locale === 'en' ? 'Skip to main content' : 'Saltar al contenido principal'}
    </a>
    <ParticlesBg />
    <Header locale={locale} />

    <!-- Barra de progreso de lectura (top fixed) -->
    <div class="reading-progress-bar" id="reading-progress" aria-hidden="true"></div>

    <main id="main-content" style="position:relative;z-index:1">
      <div class="em-container">

        <!-- ← Volver a artículos -->
        <a href={paths.articles} class="back-link">{copy.back}</a>

        <!-- Hero section -->
        <section class="hero-section">

          <!-- Cover 21:9 dentro del container, radius xl, sin efectos -->
          {cover && (
            <div class="cover-wrap">
              <Image
                src={cover}
                alt=""
                width={1440}
                height={620}
                class="cover-ambient"
                aria-hidden="true"
                loading="eager"
              />
              <Image
                src={cover}
                alt={coverAlt}
                width={1440}
                height={620}
                class="cover-img"
                transition:name={`article-cover-${slug}`}
              />
            </div>
          )}

          <!-- Meta + título + descripción + tags, centrados -->
          <div class={cover ? 'hero-content' : 'hero-content no-cover'}>
            <div class="hero-meta">
              <a href={`${paths.articles}?cat=${catSlug}`} class="hero-cat">{category.toUpperCase()}</a>
              <span class="hero-sep">·</span>
              <span>{formattedDate}</span>
              <span class="hero-sep">·</span>
              <span>{minutesRead} {copy.min}</span>
            </div>
            <h1>{title}</h1>
            <p class="hero-desc">{description}</p>
            <div class="tags-row">
              {tags.map(tag => <span class="pill">{tag}</span>)}
            </div>
          </div>
        </section>

        <!-- Divisor punteado -->
        <div class="divider-dashed" id="article-progress-start"></div>

        <!-- Grid: TOC + Prose -->
        <div class="article-body">
          <aside class="toc-col">
            <TableOfContents headings={headings} locale={locale} />
          </aside>
          <article class="prose-em">
            <slot />
          </article>
        </div>

        <!-- Author CTA inline (centrado, max-width 680px) -->
        <div class="author-cta" id="article-progress-end">
          <div class="author-avatar"></div>
          <div class="author-info">
            <strong>Edgar Martínez Palmero</strong>
            <p>{copy.authorBio}</p>
          </div>
          <a href="https://edgarmartinez.dev" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">
            {copy.portfolio} <span class="arr">↗</span>
          </a>
        </div>

        <!-- Seguir leyendo -->
        {related.length > 0 && (
          <section class="related-section">
            <div class="section-eyebrow">{copy.keepReading}</div>
            <div class="related-grid" style={`grid-template-columns: repeat(${Math.min(related.length, 3)}, 1fr)`}>
              {related.map(post => (
                <a class="em-glass em-glass-hover related-card" href={`${paths.articles}/${post.id}`} data-glass>
                  <div class="related-body">
                    <div class="em-meta">
                      <span class="cat">{post.data.category}</span>
                      <span class="dot"></span>
                      <span>{post.data.date.toLocaleDateString(getLocaleDateFormat(locale), { day: '2-digit', month: 'short', year: 'numeric' })}</span>
                    </div>
                    <h4>{post.data.title}</h4>
                    <p>{post.data.description}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

      </div>
    </main>

    <Footer locale={locale} />
  </body>
</html>

<style>
  /* ── Progreso top ─────────────────────────────────────────────────── */
  .reading-progress-bar {
    position: fixed;
    top: 0; left: 0;
    height: 2px;
    width: 0%;
    background: var(--color-em-brand);
    z-index: 200;
    transition: width 0.1s linear;
    box-shadow: 0 0 8px var(--color-em-brand-soft);
  }

  /* ── Volver ───────────────────────────────────────────────────────── */
  .back-link {
    display: inline-block;
    padding-top: 100px;
    padding-bottom: 24px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-em-fg-4);
    text-decoration: none;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-em-fg-1); }

  /* ── Hero ─────────────────────────────────────────────────────────── */
  .hero-section {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Cover — dentro del container, sin efectos, radius xl */
  .cover-wrap {
    width: 100%;
    aspect-ratio: 21 / 9;
    overflow: visible;
    border-radius: var(--radius-xl);
    position: relative;
    isolation: isolate;
    box-shadow: 0 30px 90px -48px rgba(0, 0, 0, 0.85);
  }
  .cover-ambient {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: -1;
    width: 128%;
    height: 128%;
    object-fit: cover;
    object-position: center;
    border-radius: inherit;
    opacity: 0.42;
    filter: blur(36px) saturate(1.35) brightness(1.05);
    transform: translate(-50%, -50%) scale(1.08);
    pointer-events: none;
  }
  .cover-img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* sin filter, sin overlay — imagen limpia */
  }

  /* Texto del hero, centrado */
  .hero-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .hero-content.no-cover { padding-top: 32px; }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-em-fg-4);
    letter-spacing: 0.15em;
  }
  .hero-cat {
    color: var(--color-em-brand);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .hero-cat:hover { opacity: 0.8; }
  .hero-sep { color: var(--color-em-fg-5); }

  .hero-content h1 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(40px, 4.5vw, 54px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-em-fg-1);
    text-wrap: balance;
    max-width: 18ch;
    margin: 0;
  }
  .hero-desc {
    font-size: 18px;
    color: var(--color-em-fg-3);
    line-height: 1.5;
    max-width: 38ch;
    margin: 0;
    text-wrap: pretty;
  }
  .tags-row { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }

  /* ── Divisor punteado ─────────────────────────────────────────────── */
  .divider-dashed {
    margin-top: 64px;
    border-top: 1px dashed var(--color-em-border-2);
    margin-bottom: 48px;
  }

  /* ── Grid TOC + Prose ─────────────────────────────────────────────── */
  .article-body {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 64px;
    align-items: start;
    padding-bottom: 80px;
  }

  .toc-col {
    display: block; 
    height: 100%;
  }

  /* ── Author CTA inline ────────────────────────────────────────────── */
  .author-cta {
    max-width: 680px;
    margin: 0 auto 64px;
    padding: 24px;
    border: 1px solid var(--color-em-border-2);
    border-radius: var(--radius-xl);
    background: var(--color-em-surface);
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .author-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-em-border-3), var(--color-em-border-1));
    flex-shrink: 0;
  }
  .author-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .author-info strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    color: var(--color-em-fg-1);
  }
  .author-info p {
    font-size: 13px;
    color: var(--color-em-fg-3);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Seguir leyendo ───────────────────────────────────────────────── */
  .related-section { padding-bottom: 80px; }
  .related-grid {
    display: grid;
    gap: 16px;
    margin-top: 24px;
  }
  .related-card { border-radius: var(--radius-xl) !important; }
  .related-body { padding: 24px; display: flex; flex-direction: column; gap: 10px; }
  .related-card h4 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    line-height: 1.3;
    color: var(--color-em-fg-1);
    transition: color 0.2s;
  }
  .related-card:hover h4 { color: var(--color-em-brand); }
  .related-card p { font-size: 13px; color: var(--color-em-fg-3); line-height: 1.5; }

  /* ── Prose typography ────────────────────────────────────────────── */
  .prose-em {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-em-fg-2);
    max-width: 72ch;
    position: relative;
    padding: 48px;
    padding-top: 0px;
  }

  .prose-em::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      rgba(18, 18, 21, 0.3) 0%,
      rgba(18, 18, 21, 0.5) 15%,
      rgba(18, 18, 21, 0.6) 50%,
      rgba(18, 18, 21, 0.5) 85%,
      rgba(18, 18, 21, 0.3) 100%
    );
    z-index: -1;
  }

  /* Headings */
  .prose-em :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 2.2vw, 32px);
    line-height: 1.2;
    color: var(--color-em-fg-1);
    margin-top: 48px;
    margin-bottom: 20px;
    scroll-margin-top: 120px;
  }

  .prose-em :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(20px, 1.5vw, 24px);
    line-height: 1.3;
    color: var(--color-em-fg-1);
    margin-top: 36px;
    margin-bottom: 16px;
    scroll-margin-top: 120px;
  }

  .prose-em :global(h4) {
    font-weight: 600;
    font-size: 16px;
    color: var(--color-em-fg-1);
    margin-top: 24px;
    margin-bottom: 12px;
  }

  /* Paragraphs */
  .prose-em :global(p) {
    margin: 0 0 20px 0;
  }

  .prose-em :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Lists */
  .prose-em :global(ul),
  .prose-em :global(ol) {
    margin: 20px 0;
    padding-left: 28px;
  }

  .prose-em :global(li) {
    margin-bottom: 8px;
    color: var(--color-em-fg-2);
    line-height: 1.7;
  }

  .prose-em :global(ul li) {
    list-style-type: disc;
  }

  .prose-em :global(ol li) {
    list-style-type: decimal;
  }

  .prose-em :global(li strong) {
    color: var(--color-em-fg-1);
    font-weight: 600;
  }

  /* Blockquotes */
  .prose-em :global(blockquote) {
    margin: 28px 0;
    padding: 20px 24px;
    border-left: 2px solid var(--color-em-brand);
    background: rgba(220, 240, 93, 0.04);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .prose-em :global(blockquote p) {
    font-style: italic;
    font-size: 16px;
    color: var(--color-em-fg-3);
    margin: 0;
    line-height: 1.6;
  }

  .prose-em :global(blockquote p + p) {
    margin-top: 12px;
  }

  .prose-em :global(blockquote strong) {
    color: var(--color-em-fg-2);
    font-weight: 500;
  }

  /* Code inline */
  .prose-em :global(code:not(pre code)) {
    font-family: var(--font-mono);
    font-size: 14px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--color-em-border-2);
    border-radius: 4px;
    padding: 2px 6px;
    color: var(--color-em-fg-2);
  }

  /* Pre / Code blocks */
  .prose-em :global(pre) {
    margin: 28px 0;
    overflow-x: auto;
    border: 1px solid var(--color-em-border-2);
    border-radius: var(--radius-lg);
    background: rgba(18, 18, 21, 0.5);
    padding: 16px;
  }

  .prose-em :global(pre code) {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-em-fg-2);
    background: none;
    border: none;
    padding: 0;
  }

  /* Horizontal rule */
  .prose-em :global(hr) {
    margin: 48px 0;
    border: none;
    border-top: 1px dashed var(--color-em-border-2);
  }

  /* Tables */
  .prose-em :global(table) {
    width: 100%;
    margin: 28px 0;
    border-collapse: collapse;
    font-size: 14px;
  }

  .prose-em :global(th) {
    text-align: left;
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 12px 16px;
    border-bottom: 2px solid var(--color-em-border-2);
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-em-fg-3);
  }

  .prose-em :global(td) {
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-em-border-1);
    color: var(--color-em-fg-2);
  }

  .prose-em :global(tr:last-child td) {
    border-bottom: none;
  }

  /* Links */
  .prose-em :global(a) {
    color: var(--color-em-brand);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .prose-em :global(a:hover) {
    border-bottom-color: var(--color-em-brand);
  }

  /* Strong & emphasis */
  .prose-em :global(strong) {
    color: var(--color-em-fg-1);
    font-weight: 600;
  }

  .prose-em :global(em) {
    font-style: italic;
    color: var(--color-em-fg-2);
  }

  /* Callout components */
  .prose-em :global(.callout) {
    margin: 28px 0;
  }

  /* Image captions */
  .prose-em :global(figure) {
    margin: 28px 0;
    text-align: center;
  }

  .prose-em :global(figcaption) {
    font-size: 13px;
    color: var(--color-em-fg-4);
    margin-top: 12px;
    font-style: italic;
  }

  /* ── Responsive ───────────────────────────────────────────────────── */
  @media (max-width: 960px) {
    .article-body { grid-template-columns: 1fr; }
    .toc-col { display: none; }
    .cover-wrap { aspect-ratio: 16 / 9; }
  }
  @media (max-width: 640px) {
    .back-link { padding-top: 80px; }
    .hero-content h1 { font-size: clamp(32px, 8vw, 44px); }
    .hero-desc { font-size: 16px; }
    .author-cta { flex-wrap: wrap; }
    .author-cta .btn { width: 100%; justify-content: center; }

    .prose-em :global(h2) { margin-top: 36px; font-size: clamp(24px, 6vw, 28px); }
    .prose-em :global(h3) { margin-top: 24px; font-size: clamp(18px, 5vw, 20px); }
    .prose-em :global(blockquote) { padding: 16px 20px; }
    .prose-em :global(pre) { padding: 12px; font-size: 12px; }
  }
</style>

<script>
  // Glass border effect en cards relacionadas
  document.querySelectorAll<HTMLElement>('[data-glass]').forEach(el => {
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const r = el.getBoundingClientRect();
      el.style.setProperty('--mx', (e.clientX - r.left) + 'px');
      el.style.setProperty('--my', (e.clientY - r.top) + 'px');
    });
  });

  // Progress bar top: cuenta solo desde el separador del articulo hasta el CTA del autor
  const bar = document.getElementById('reading-progress') as HTMLElement | null;
  if (bar) {
    function updateBar() {
      const startEl = document.getElementById('article-progress-start');
      const endEl = document.getElementById('article-progress-end');
      if (!startEl || !endEl) return;

      const start = startEl.getBoundingClientRect().top + window.scrollY;
      const end = endEl.getBoundingClientRect().top + window.scrollY;
      const total = Math.max(1, end - start);
      const scrolled = window.scrollY - start;
      const pct = Math.min(100, Math.max(0, (scrolled / total) * 100));

      bar!.style.width = pct + '%';
    }
    window.addEventListener('scroll', updateBar, { passive: true });
    window.addEventListener('resize', updateBar);
    window.addEventListener('astro:page-load', updateBar);
    updateBar();
  }
</script>
